{
  "name": "instagram-official-autoposter",
  "version": "1.0.0",
  "description": "Automacao local para publicar videos no Instagram usando somente a API oficial da Meta.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cron:publish": "node dist/src/cron-entry.js",
    "dev": "tsx watch src/index.ts",
    "db:up": "docker compose up -d postgres",
    "db:logs": "docker compose logs -f postgres",
    "once": "tsx src/index.ts once"
  },
  "keywords": [
    "instagram",
    "meta",
    "graph-api",
    "reels",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mime-types": "^2.1.35",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@vercel/node": "^5.8.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}